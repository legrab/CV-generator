{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/cv.schema.json",
  "title": "CV Builder Data",
  "type": "object",
  "required": ["profile", "content"],
  "additionalProperties": false,
  "properties": {
    "profile": {
      "type": "object",
      "required": ["name", "headline", "contact"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string"
        },
        "headline": {
          "type": "string"
        },
        "location": {
          "type": "string"
        },
        "contact": {
          "type": "object",
          "required": ["email"],
          "additionalProperties": false,
          "properties": {
            "email": {
              "type": "string"
            },
            "phone": {
              "type": "string"
            },
            "website": {
              "type": "string"
            },
            "linkedin": {
              "type": "string"
            },
            "github": {
              "type": "string"
            }
          }
        }
      }
    },
    "settings": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "defaultLanguage": {
          "type": "string"
        },
        "languages": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "content": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/localizedContent"
      }
    }
  },
  "$defs": {
    "localizedContent": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "summary": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "sidebar": {
          "$ref": "#/$defs/sidebar"
        },
        "experience": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/experienceItem"
          }
        },
        "projects": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/projectItem"
          }
        },
        "education": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/educationItem"
          }
        },
        "certifications": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/simpleItem"
          }
        },
        "languages": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/simpleItem"
          }
        },
        "publications": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/simpleItem"
          }
        }
      }
    },
    "sidebar": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "sections": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/sidebarSection"
          }
        }
      }
    },
    "sidebarSection": {
      "type": "object",
      "required": ["title", "items"],
      "additionalProperties": false,
      "properties": {
        "title": {
          "type": "string"
        },
        "items": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "experienceItem": {
      "type": "object",
      "required": ["company", "title", "period"],
      "additionalProperties": false,
      "properties": {
        "company": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "location": {
          "type": "string"
        },
        "period": {
          "type": "string"
        },
        "intro": {
          "type": "string"
        },
        "bullets": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "technologies": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "layout": {
          "$ref": "#/$defs/layout"
        }
      }
    },
    "projectItem": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string"
        },
        "period": {
          "type": "string"
        },
        "associatedWith": {
          "type": "string"
        },
        "intro": {
          "type": "string"
        },
        "bullets": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "technologies": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "links": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/link"
          }
        },
        "layout": {
          "$ref": "#/$defs/layout"
        }
      }
    },
    "educationItem": {
      "type": "object",
      "required": ["institution", "degree", "period"],
      "additionalProperties": false,
      "properties": {
        "institution": {
          "type": "string"
        },
        "degree": {
          "type": "string"
        },
        "period": {
          "type": "string"
        },
        "location": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "areas": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "layout": {
          "$ref": "#/$defs/layout"
        }
      }
    },
    "simpleItem": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "object",
          "required": ["name"],
          "additionalProperties": false,
          "properties": {
            "name": {
              "type": "string"
            },
            "description": {
              "type": "string"
            },
            "period": {
              "type": "string"
            },
            "issuer": {
              "type": "string"
            },
            "url": {
              "type": "string"
            }
          }
        }
      ]
    },
    "link": {
      "type": "object",
      "required": ["label", "url"],
      "additionalProperties": false,
      "properties": {
        "label": {
          "type": "string"
        },
        "url": {
          "type": "string"
        }
      }
    },
    "layout": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "visible": {
          "type": "boolean"
        },
        "pageBreakBefore": {
          "type": "boolean"
        },
        "avoidBreakInside": {
          "type": "boolean"
        }
      }
    }
  }
}
